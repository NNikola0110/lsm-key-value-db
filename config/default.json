{
  "data_dir": "./data",
  "memtable_max_bytes": 67108864,
  "max_immutable_tables": 4,
  "memtable_size_overhead_bytes_per_entry": 32,
  "block_size": 8192,
  "bloom_false_positive": 0.01,
  "restart_interval": 16,
  "max_build_buffer_mb": 32,
  "block_cache_mb": 64,
  "cache_index_blocks": true,
  "max_open_files": 1024,
  "wal_fsync_every_n": 1,
  "wal_segment_roll_bytes": 134217728,
  "compression": "off",
  "log_level": "info",
  "publish_log_level": "info"
}
